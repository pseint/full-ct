function textPrint(txt,duration)
    executeCodeEx(0,100,getAddress("TextPrint"),{3,txt or ""},{1,duration or 7.0})
end

function CBRoshanSpawn(param)
    if roshan_notifier_counter ~= 0 then
        textPrint("|c0096FF96Byakugan MapHack|r:")
        textPrint("        ¡|c006969FFRoshan is alive|r!")
    end
    roshan_notifier_counter = roshan_notifier_counter + 1
end

