  <LuaScript>--  WARCRAFT III MULTIHACK PRO v2  —  UI MATERIAL 2026 (v7 - DEFINITIVO)
--  Script Lua NATIVO para Cheat Engine 7.4+
--   x FIX RECTANGULOS NEGROS: Pen.Style=psClear en TODO el dibujado de botones
--   x CHECKBOX MATERIAL custom (dibujado propio -&gt; texto SIEMPRE visible/color tema)
--   x CONSOLA LUA: oculta al inicio (cbShowOnPrint=false + hide + OnShow=hide)
--   x HOTKEY ADMIN OCULTO: Ctrl+Alt+Shift+L alterna la consola Lua
--   x GRADIENTE SUAVE dithering + botones redondeados planos
--   x 6 temas + fondo gamer Gen-Z 2026 nativo + particulas optimizadas + layout responsive
--   x Sin crashes (alive/pcall/cleanup/timers por sesion)
-- ============================================================================

if getCEVersion() &lt; 7.4 then
  showMessage("Requiere Cheat Engine 7.4+")
  return
end

_G.__REFS = _G.__REFS or { hotkeys = {}, timers = {}, forms = {} }
local REFS = _G.__REFS

-- ============================================================================
--  CONSOLA LUA: ocultarla por completo y evitar que aparezca sola
--  (API oficial de CE: getLuaEngine, cbShowOnPrint, hide/show)
-- ============================================================================
local consoleVisible = false
local function setupConsoleHidden()
  pcall(function()
    local le = getLuaEngine()
    if le then
      pcall(function() le.cbShowOnPrint.Checked = false end)  -- no aparece al imprimir
      pcall(function() le.hide() end)                          -- oculta ahora
      pcall(function() le.OnShow = function(sender) pcall(function() sender.hide() end); return true end end)
    end
  end)
end
-- alterna la consola (admin)
function toggleLuaConsole()
  local le = nil
  pcall(function() le = getLuaEngine() end)
  if not le then return end
  consoleVisible = not consoleVisible
  pcall(function()
    if consoleVisible then
      le.OnShow = nil          -- quitar el bloqueo para poder mostrarla
      le.show()
      le.BringToFront()
    else
      le.hide()
      le.OnShow = function(sender) pcall(function() sender.hide() end); return true end
    end
  end)
end

-- ============================================================================
--  HELPERS DE COLOR
-- ============================================================================
local function rgb(r, g, b)
  r = math.floor(r+0.5); g = math.floor(g+0.5); b = math.floor(b+0.5)
  return (b * 0x10000) + (g * 0x100) + r
end
local function comps(c)
  return c % 256, math.floor(c / 256) % 256, math.floor(c / 65536) % 256
end
local function lerp(a, b, t) return a + (b - a) * t end
local function clamp255(v)
  if v &lt; 0 then return 0 elseif v &gt; 255 then return 255 else return math.floor(v + 0.5) end
end
local function colorLerp(c1, c2, t)
  local r1, g1, b1 = comps(c1); local r2, g2, b2 = comps(c2)
  return rgb(lerp(r1,r2,t), lerp(g1,g2,t), lerp(b1,b2,t))
end
local function darken(c, a)
  local r, g, b = comps(c); return rgb(lerp(r,0,a), lerp(g,0,a), lerp(b,0,a))
end
local function lighten(c, a)
  local r, g, b = comps(c); return rgb(lerp(r,255,a), lerp(g,255,a), lerp(b,255,a))
end
local function textW(canvas, s)
  local ok, v = pcall(function() return canvas.getTextWidth(s) end)
  if ok and type(v) == "number" then return v end
  return #s * 6
end
local function textH(canvas, s)
  local ok, v = pcall(function() return canvas.getTextHeight(s) end)
  if ok and type(v) == "number" then return v end
  return 16
end

-- ============================================================================
--  TEMAS
-- ============================================================================
